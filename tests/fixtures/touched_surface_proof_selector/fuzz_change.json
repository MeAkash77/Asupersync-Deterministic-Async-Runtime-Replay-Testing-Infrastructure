{
  "schema_version": "touched-surface-proof-selector-input-v1",
  "touched_files": ["fuzz/Cargo.toml", "fuzz/fuzz_targets/http_header_map_invariants.rs"],
  "lanes": [
    {
      "lane_id": "fuzz-manifest-smoke",
      "kind": "compile_frontier",
      "command": "rch exec -- cargo check --manifest-path fuzz/Cargo.toml",
      "guarantee_ids": ["fuzz-manifest-smoke"],
      "source_paths": ["fuzz/Cargo.toml", "fuzz/fuzz_targets/**"],
      "covers": "fuzz manifest and registered targets typecheck",
      "explicit_not_covered": "coverage-guided campaigns",
      "broad_frontier": false
    },
    {
      "lane_id": "rustfmt-frontier",
      "kind": "format_frontier",
      "command": "rch exec -- cargo fmt --check",
      "guarantee_ids": ["rustfmt-frontier"],
      "source_paths": ["src/**", "tests/**", "fuzz/**"],
      "covers": "formatting frontier",
      "explicit_not_covered": "type checking",
      "broad_frontier": true
    }
  ],
  "selection_rules": [
    {
      "rule_id": "fuzz-target",
      "patterns": ["fuzz/Cargo.toml", "fuzz/fuzz_targets/**"],
      "lane_ids": ["fuzz-manifest-smoke"],
      "supplemental_lane_ids": ["rustfmt-frontier"],
      "reason": "fuzz target or manifest changes need fuzz manifest smoke proof"
    }
  ]
}
