{
  "lanes": [
    {
      "lane_id": "lib-tests",
      "kind": "test_frontier",
      "command": "rch exec -- cargo test -p asupersync --lib",
      "guarantee_ids": ["lib-test-frontier"],
      "source_paths": ["src/**"],
      "covers": "runtime crate unit-test frontier",
      "explicit_not_covered": "integration tests and fuzz targets",
      "broad_frontier": false
    },
    {
      "lane_id": "all-targets-check",
      "kind": "compile_frontier",
      "command": "rch exec -- cargo check -p asupersync --all-targets",
      "guarantee_ids": ["all-target-compile-frontier"],
      "source_paths": ["src/**", "tests/**"],
      "covers": "runtime crate all-target compile frontier",
      "explicit_not_covered": "workspace satellite crates and fuzz manifest",
      "broad_frontier": true
    },
    {
      "lane_id": "fuzz-manifest-smoke",
      "kind": "compile_frontier",
      "command": "rch exec -- cargo check --manifest-path fuzz/Cargo.toml",
      "guarantee_ids": ["fuzz-manifest-smoke"],
      "source_paths": ["fuzz/Cargo.toml", "fuzz/fuzz_targets/**"],
      "covers": "fuzz manifest and registered targets typecheck",
      "explicit_not_covered": "coverage-guided campaigns",
      "broad_frontier": false
    },
    {
      "lane_id": "rustfmt-frontier",
      "kind": "format_frontier",
      "command": "rch exec -- cargo fmt --check",
      "guarantee_ids": ["rustfmt-frontier"],
      "source_paths": ["src/**", "tests/**", "fuzz/**"],
      "covers": "formatting frontier",
      "explicit_not_covered": "type checking",
      "broad_frontier": true
    },
    {
      "lane_id": "default-production-tokio-tree",
      "kind": "dependency_graph",
      "command": "rch exec -- cargo tree -e normal -p asupersync -i tokio",
      "guarantee_ids": ["default-production-tokio-free"],
      "source_paths": ["Cargo.toml"],
      "covers": "default production dependency graph has no tokio edge",
      "explicit_not_covered": "workspace and fuzz graphs",
      "broad_frontier": false
    },
    {
      "lane_id": "proof-lane-manifest-contract",
      "kind": "test_frontier",
      "command": "rch exec -- cargo test -p asupersync --test proof_lane_manifest_contract",
      "guarantee_ids": ["proof-lane-manifest-verifier"],
      "source_paths": ["artifacts/proof_lane_manifest_v1.json", "tests/proof_lane_manifest_contract.rs"],
      "covers": "proof lane manifest contract",
      "explicit_not_covered": "actual proof command execution",
      "broad_frontier": false
    }
  ],
  "selection_rules": [
    {
      "rule_id": "runtime-source",
      "patterns": ["src/**"],
      "lane_ids": ["lib-tests"],
      "supplemental_lane_ids": ["all-targets-check", "rustfmt-frontier"],
      "reason": "runtime source change needs lib-frontier proof plus broad compile/format frontier"
    },
    {
      "rule_id": "integration-test",
      "patterns": ["tests/**"],
      "lane_ids": ["all-targets-check"],
      "supplemental_lane_ids": ["rustfmt-frontier"],
      "reason": "integration test changes compile through all-targets"
    },
    {
      "rule_id": "fuzz-target",
      "patterns": ["fuzz/Cargo.toml", "fuzz/fuzz_targets/**"],
      "lane_ids": ["fuzz-manifest-smoke"],
      "supplemental_lane_ids": ["rustfmt-frontier"],
      "reason": "fuzz target or manifest changes need fuzz manifest smoke proof"
    },
    {
      "rule_id": "dependency-manifest",
      "patterns": ["Cargo.toml", "Cargo.lock"],
      "lane_ids": ["default-production-tokio-tree"],
      "supplemental_lane_ids": ["all-targets-check"],
      "reason": "dependency changes need production graph proof and compile frontier"
    }
  ]
}
